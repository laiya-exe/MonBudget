<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/logo_monbudget"
        android:label="@string/app_name"
        android:roundIcon="@drawable/logo_monbudget"
        android:supportsRtl="true"
        android:theme="@style/Theme.MonBudget">

        <!-- Splash Screen : écran de lancement -->
        <activity
            android:name=".ui.activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- MainActivity : écran principal avec BottomNavigation -->
        <activity
            android:name=".ui.activities.MainActivity" />

        <!-- RevenusActivity -->
        <activity
            android:name="com.tp.gestiondepenses.ui.activities.RevenusActivity"
            android:exported="true" />

    </application>

</manifest>