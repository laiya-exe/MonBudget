<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.MonBudget">

        <activity
            android:name=".ui.activities.DetailDepenseActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.FormulaireCategorieActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.GestionCategoriesActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.DetailBudgetActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.FormulaireBudgetActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.FormulaireDepenseActivity"
            android:exported="false"
            android:label="Nouvelle dépense" />

        <!-- Splash Screen : écran de lancement -->
        <activity
            android:name=".ui.activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- MainActivity : écran principal avec BottomNavigation -->
        <activity android:name=".ui.activities.MainActivity" />

        <!-- RevenusActivity -->
        <activity
            android:name=".ui.activities.RevenusActivity"
            android:exported="true" />

        <!-- DetailsRevenusActivity -->
        <activity
            android:name=".ui.activities.DetailsRevenusActivity"
            android:exported="true" />

        <!-- FormulaireRevenusActivity -->
        <activity
            android:name=".ui.activities.FormulaireRevenusActivity"
            android:exported="true" />

    </application>

</manifest>