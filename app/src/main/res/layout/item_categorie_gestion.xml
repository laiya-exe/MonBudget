<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <!-- Gauche - Icône avec fond arrondi -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardIconBg"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardBackgroundColor="#FFF3E0"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <ImageView
                android:id="@+id/ivCategoryIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_category"
                app:tint="@color/orange_budget" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Centre - Nom -->
        <TextView
            android:id="@+id/tvNom"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:text="Alimentation"
            android:textColor="@color/text_black_dark"
            android:textSize="16sp" />

        <!-- Badge -->
        <TextView
            android:id="@+id/tvBadgePerso"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_badge_purple_light"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="PERSO"
            android:textColor="@color/violet_custom"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:visibility="visible" />

        <!-- Droite - Chevron -->
        <ImageView
            android:id="@+id/ivChevron"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_back"
            android:rotation="180"
            app:tint="@color/text_gray_light" />

    </LinearLayout>

    <!-- Séparateur -->
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="72dp"
        android:background="@color/divider_gray" />

</LinearLayout>
