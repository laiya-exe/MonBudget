<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary_blue"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="@color/white"
        app:title="Revenus"
        app:titleTextColor="@color/white" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Formulaire d'ajout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Montant obligatoire -->
            <EditText
                android:id="@+id/edtMontant"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Montant (FCFA)"
                android:inputType="numberDecimal" />

            <!-- Source obligatoire (liste déroulante) -->
            <Spinner
                android:id="@+id/spinnerSource"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Champ texte affiché seulement si 'Autre' est choisi -->
            <EditText
                android:id="@+id/edtSourceAutre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Précisez la source"
                android:visibility="gone" />

            <!-- Date obligatoire (sélection via calendrier) -->
            <EditText
                android:id="@+id/edtDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="false"
                android:hint="Date" />

            <!-- Description optionnelle -->
            <EditText
                android:id="@+id/edtDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Description (optionnelle)" />

            <!-- Bouton d’ajout -->
            <Button
                android:id="@+id/btnAjouter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Ajouter revenu" />
        </LinearLayout>

        <!-- Liste des revenus -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerRevenus"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="16dp" />
    </LinearLayout>
</LinearLayout>