<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="6dp"
    android:background="@android:color/white">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Bloc texte à gauche -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentStart="true">

            <!-- Catégorie (remplace Source) -->
            <TextView
                android:id="@+id/txtCategorie"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Catégorie"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@android:color/black"/>

            <!-- Montant (couleur rouge pour les dépenses) -->
            <TextView
                android:id="@+id/txtMontant"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Montant"
                android:textSize="14sp"
                android:textColor="@android:color/holo_red_dark"
                android:layout_marginTop="4dp"/>

            <!-- Moyen de paiement (NOUVEAU) -->
            <TextView
                android:id="@+id/txtMoyenPaiement"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Moyen de paiement"
                android:textSize="12sp"
                android:textColor="@android:color/darker_gray"
                android:layout_marginTop="2dp"/>

            <!-- Description -->
            <TextView
                android:id="@+id/txtDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textSize="14sp"
                android:textColor="@android:color/darker_gray"
                android:layout_marginTop="2dp"
                android:visibility="gone"/>

            <!-- Date -->
            <TextView
                android:id="@+id/txtDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date : "
                android:textSize="12sp"
                android:textColor="@android:color/darker_gray"
                android:layout_marginTop="2dp"/>

            <!-- Pourcentage -->
            <TextView
                android:id="@+id/txtPourcentage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pourcentage"
                android:textSize="12sp"
                android:textColor="@android:color/holo_blue_dark"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- Image à droite (icône catégorie) -->
        <ImageView
            android:id="@+id/imgCategorieIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:contentDescription="Icône dépense"
            android:src="@android:drawable/stat_notify_error"/>

    </RelativeLayout>

</androidx.cardview.widget.CardView>