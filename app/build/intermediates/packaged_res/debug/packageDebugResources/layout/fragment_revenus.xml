<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Titre -->
        <TextView
            android:id="@+id/txtTitreRevenus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mes Revenus"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="8dp"/>

        <!-- Total -->
        <TextView
            android:id="@+id/txtTotalRevenus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total: 0 FCFA"
            android:textSize="16sp"
            android:textColor="@android:color/holo_green_dark"
            android:layout_marginBottom="12dp"/>

        <!-- Message croissance -->
        <TextView
            android:id="@+id/txtMessageCroissance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Répartition par source de revenus"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginBottom="16dp"/>

        <!-- Filtre par mois -->
        <Spinner
            android:id="@+id/spinnerMois"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"/>

        <!-- Liste des revenus -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerRevenus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>

        <!-- Boutons -->
        <Button
            android:id="@+id/btnVoirDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voir les détails"/>

        <Button
            android:id="@+id/btnAjouterRevenu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ajouter un revenu"
            android:layout_marginTop="8dp"/>
    </LinearLayout>
</ScrollView>
